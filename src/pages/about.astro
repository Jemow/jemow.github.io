---
import PageLayout from '../layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import cfpt from '../assets/CFPT.png';
import sae from '../assets/SAE.png';
import unity from '../assets/UNITY.jpg';
---

<PageLayout
	title="About the studio"
	description="We shape product, brand, and code for mission-driven teams."
	eyebrow="Studio"
>
	<section class="content-shell py-12 space-y-8">
		<div class="space-y-3 max-w-3xl">
			<p class="m-0 text-ink text-2xl font-semibold leading-tight">Game Programming student, mainly using Unity for my games.</p>
					<div class="flex flex-wrap items-center gap-6 pt-4">
			<Image src={cfpt} alt="CFPT" class="h-60 w-auto object-contain" />
			<Image src={sae} alt="SAE Institute" class="h-60 w-auto object-contain" />
			<Image src={unity} alt="Unity" class="h-60 w-auto object-contain" />
		</div>
			<p class="m-0 text-muted">Hi! My name is Jemoel and I'm 21 years old, I enjoy programming, especially in <b style="color: white">C#</b> and <b style="color: white">C++</b>. In my free time, I like creating games, and it has become my main passion.
                        I first studied <b style="color: white">web</b> and <b style="color: white">application</b> development at <b style="color: white">CFPT</b>, where I built a <b style="color: white">social media website</b> for my final exam. Later,
                        I decided to focus on game development and joined <b style="color: white">SAE Institute</b>.

                        Making games feels natural to me, I see it as fun and creative rather than just work. I'm always learning and improving my skills,
                        with the goal of growing as a game developer and contributing to the industry.</p>
		</div>

	</section>
</PageLayout>
